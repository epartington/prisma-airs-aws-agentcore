# ─────────────────────────────────────────────────────────────────────────────
# Prisma AIRS × AWS Bedrock AgentCore — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: Prisma AIRS ────────────────────────────────────────────────────
# Obtain from Prisma Cloud console → AI Security → API Keys
export PRISMA_AIRS_API_KEY="your-prisma-airs-api-key-here"

# Name of the AI Security Profile configured in Prisma Cloud
# (Prisma Cloud → AI Security → Profiles → copy the profile name exactly)
export PRISMA_AIRS_PROFILE_NAME="your-profile-name-here"

# Optional: override the AIRS service URL (leave as-is for production)
export PRISMA_AIRS_URL="https://service.api.aisecurity.paloaltonetworks.com"

# ── Required: AWS credentials ────────────────────────────────────────────────
# Standard AWS credential env vars — used for Bedrock model calls
export AWS_ACCESS_KEY_ID="your-aws-access-key-id"
export AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
export AWS_DEFAULT_REGION="us-west-2"

# If using temporary credentials (IAM role / STS AssumeRole):
# export AWS_SESSION_TOKEN="your-session-token"

# ── Optional: Bedrock model override ─────────────────────────────────────────
# Default: Claude Haiku 4.5 cross-region inference profile
# export BEDROCK_MODEL_ID="us.anthropic.claude-haiku-4-5-20251001-v1:0"

# ── Optional: application label shown in AIRS scan reports ──────────────────
# export AIRS_APP_NAME="Agentcore-AIRS-POV"
